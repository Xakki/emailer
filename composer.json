{
  "name": "xakki/emailer",
  "description": "Self-hosted transactional & notification email service with templating, tracking, subscription management and an HTTP/console API",
  "type": "library",
  "license": "GPL-3.0-or-later",
  "keywords": [
    "email",
    "mailer",
    "smtp",
    "notification",
    "transactional-email",
    "email-tracking",
    "phpmailer",
    "doctrine"
  ],
  "homepage": "https://github.com/Xakki/emailer",
  "authors": [
    {
      "name": "Xakki",
      "email": "xakki@ya.ru",
      "homepage": "https://github.com/Xakki"
    }
  ],
  "support": {
    "issues": "https://github.com/Xakki/emailer/issues",
    "source": "https://github.com/Xakki/emailer"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "require": {
    "php": ">=8.4",
    "ext-pdo": "*",
    "ext-json": "*",
    "ext-fileinfo": "*",
    "ext-redis": "*",
    "psr/log": "^3.0",
    "phpmailer/phpmailer": "^6.9",
    "doctrine/dbal": "^4.2",
    "doctrine/migrations": "^3.8",
    "phroute/phroute": "^2.2",
    "monolog/monolog": "^3.5"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "phpstan/phpstan": "^2.1",
    "squizlabs/php_codesniffer": "^3.11",
    "opsway/psr12-strict-coding-standard": "^1.1"
  },
  "scripts": {
    "phpunit": "phpunit -c phpunit.xml",
    "test": "phpunit -c phpunit.xml",
    "test-coverage": "phpunit -c phpunit.xml --coverage-text --coverage-html=build/coverage",
    "phpstan": "phpstan analyse --memory-limit 1G",
    "cs-check": "phpcs",
    "cs-fix": "phpcbf",
    "cs-commit-check": "git diff --name-only --diff-filter=AM origin/master | grep .php | xargs composer cs-check",
    "cs-commit-fix": "git diff --name-only --diff-filter=AM origin/master | grep .php | xargs composer cs-fix"
  },
  "autoload": {
    "psr-4": {
      "Xakki\\Emailer\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Xakki\\Emailer\\Tests\\": "tests"
    }
  }
}
